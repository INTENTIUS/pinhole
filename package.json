{
  "name": "@intentius/pinhole",
  "version": "0.2.2",
  "type": "module",
  "description": "Agentic infra diagrammer — paints chant's graph IR into diagrams, gated by lint at every step",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "pinhole": "./bin/pinhole.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "bin",
    "dist"
  ],
  "scripts": {
    "tsc": "tsc --noEmit",
    "test": "vitest run",
    "gen:agents": "node --experimental-strip-types -e \"import('./src/guide.ts').then(m=>process.stdout.write(m.GUIDE))\" > AGENTS.md",
    "build:lib": "esbuild src/index.ts --bundle --platform=node --format=esm --external:@intentius/chant --outfile=dist/index.js",
    "build:cli": "esbuild src/cli.ts --bundle --platform=node --format=esm --external:@intentius/chant --outfile=dist/cli.js && chmod +x dist/cli.js",
    "build:types": "tsc -p tsconfig.build.json",
    "build": "npm run build:lib && npm run build:cli && npm run build:types",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@intentius/chant": "^0.13.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/INTENTIUS/pinhole.git"
  },
  "bugs": {
    "url": "https://github.com/INTENTIUS/pinhole/issues"
  },
  "homepage": "https://github.com/INTENTIUS/pinhole#readme"
}
